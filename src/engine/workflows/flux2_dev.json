{
  "unet": {
    "inputs": { "unet_name": "flux2_dev_fp8mixed.safetensors", "weight_dtype": "default" },
    "class_type": "UNETLoader"
  },
  "clip": {
    "inputs": { "clip_name": "mistral_3_small_flux2_bf16.safetensors", "type": "flux2", "device": "default" },
    "class_type": "CLIPLoader"
  },
  "vae": {
    "inputs": { "vae_name": "flux2-vae.safetensors" },
    "class_type": "VAELoader"
  },
  "pos": {
    "inputs": { "text": "", "clip": ["clip", 0] },
    "class_type": "CLIPTextEncode"
  },
  "guidance": {
    "inputs": { "conditioning": ["pos", 0], "guidance": 4.0 },
    "class_type": "FluxGuidance"
  },
  "zero": {
    "inputs": { "conditioning": ["pos", 0] },
    "class_type": "ConditioningZeroOut"
  },
  "latent": {
    "inputs": { "width": 1024, "height": 1024, "batch_size": 1 },
    "class_type": "EmptySD3LatentImage"
  },
  "sampler": {
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["unet", 0],
      "positive": ["guidance", 0],
      "negative": ["zero", 0],
      "latent_image": ["latent", 0]
    },
    "class_type": "KSampler"
  },
  "decode": {
    "inputs": { "samples": ["sampler", 0], "vae": ["vae", 0] },
    "class_type": "VAEDecode"
  },
  "save": {
    "inputs": { "filename_prefix": "aurora", "images": ["decode", 0] },
    "class_type": "SaveImage"
  }
}
